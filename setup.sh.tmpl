#!/usr/bin/env bash
# ============================================================================
# ln-setup.sh — Configure your machine to resolve 'ln' as a hostname
#
# This adds an entry to /etc/hosts so that 'ln' resolves to the
# {{SITE_HOST}} server. After setup, you can use:
#
#   curl http://ln/yt          # from terminal
#   http://ln/yt               # in any browser
#   <a href="http://ln/yt">    # in documents
#
# Usage:
#   curl -fsSL {{BASE_URL}}/_/setup.sh | sudo bash
#   # or
#   sudo ./ln-setup.sh
#   # or to uninstall:
#   sudo ./ln-setup.sh --remove
#
# Supports: Linux, macOS, WSL
# ============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

HOSTNAME="ln"
# Resolve the actual IP of {{SITE_HOST}} at install time
TARGET_HOST="{{SITE_HOST}}"
MARKER="# {{SITE_HOST}} shortlink service"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

info()  { printf "\033[1;34m→\033[0m %s\n" "$*"; }
ok()    { printf "\033[1;32m✔\033[0m %s\n" "$*"; }
warn()  { printf "\033[1;33m!\033[0m %s\n" "$*"; }
err()   { printf "\033[1;31m✘\033[0m %s\n" "$*" >&2; }

check_root() {
  if [ "$(id -u)" -ne 0 ]; then
    err "This script must be run as root (use sudo)."
    exit 1
  fi
}

detect_os() {
  case "$(uname -s)" in
    Linux*)  echo "linux" ;;
    Darwin*) echo "macos" ;;
    MINGW*|CYGWIN*|MSYS*) echo "windows" ;;
    *) echo "unknown" ;;
  esac
}

resolve_ip() {
  # Try multiple methods to resolve the IP
  local ip=""

  # Method 1: dig
  if command -v dig &>/dev/null; then
    ip=$(dig +short "$TARGET_HOST" A 2>/dev/null | head -1)
  fi

  # Method 2: host
  if [ -z "$ip" ] && command -v host &>/dev/null; then
    ip=$(host "$TARGET_HOST" 2>/dev/null | awk '/has address/ { print $4; exit }')
  fi

  # Method 3: getent
  if [ -z "$ip" ] && command -v getent &>/dev/null; then
    ip=$(getent hosts "$TARGET_HOST" 2>/dev/null | awk '{ print $1; exit }')
  fi

  # Method 4: python
  if [ -z "$ip" ] && command -v python3 &>/dev/null; then
    ip=$(python3 -c "import socket; print(socket.gethostbyname('$TARGET_HOST'))" 2>/dev/null)
  fi

  if [ -z "$ip" ]; then
    err "Could not resolve $TARGET_HOST. Check your DNS / internet connection."
    exit 1
  fi

  echo "$ip"
}

flush_dns() {
  local os="$1"
  case "$os" in
    macos)
      info "Flushing DNS cache..."
      dscacheutil -flushcache 2>/dev/null || true
      killall -HUP mDNSResponder 2>/dev/null || true
      ;;
    linux)
      # systemd-resolved
      if command -v resolvectl &>/dev/null; then
        info "Flushing systemd-resolved cache..."
        resolvectl flush-caches 2>/dev/null || true
      # nscd
      elif command -v nscd &>/dev/null; then
        info "Flushing nscd cache..."
        nscd -i hosts 2>/dev/null || true
      fi
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Install
# ---------------------------------------------------------------------------

install_hosts_entry() {
  local ip="$1"
  local os="$2"
  local hosts_file="/etc/hosts"

  # Check if already present
  if grep -qF "$MARKER" "$hosts_file" 2>/dev/null; then
    warn "Entry already exists in $hosts_file. Updating..."
    remove_hosts_entry "$os" quiet
  fi

  info "Adding '$HOSTNAME' → $ip to $hosts_file"
  printf "\n%s    %s    %s\n" "$ip" "$HOSTNAME" "$MARKER" >> "$hosts_file"

  flush_dns "$os"
  ok "Done! You can now use:"
  echo ""
  echo "    curl -L http://ln/yt"
  echo "    open http://ln/yt        # (browser)"
  echo ""
  echo "  In any hyperlink:  http://ln/yt"
  echo ""
}

# ---------------------------------------------------------------------------
# Remove
# ---------------------------------------------------------------------------

remove_hosts_entry() {
  local os="$1"
  local quiet="${2:-}"
  local hosts_file="/etc/hosts"

  if ! grep -qF "$MARKER" "$hosts_file" 2>/dev/null; then
    [ -z "$quiet" ] && warn "No ln entry found in $hosts_file. Nothing to remove."
    return 0
  fi

  [ -z "$quiet" ] && info "Removing ln entry from $hosts_file"

  # Use sed to remove the line containing our marker
  if [ "$(detect_os)" = "macos" ]; then
    sed -i '' "/$MARKER/d" "$hosts_file"
  else
    sed -i "/$MARKER/d" "$hosts_file"
  fi

  # Remove any trailing blank lines we may have left
  if [ "$(detect_os)" = "macos" ]; then
    sed -i '' -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$hosts_file" 2>/dev/null || true
  fi

  flush_dns "$os"
  [ -z "$quiet" ] && ok "Removed. 'ln' will no longer resolve locally."
}

# ---------------------------------------------------------------------------
# Windows instructions (can't auto-edit from bash easily)
# ---------------------------------------------------------------------------

windows_instructions() {
  local ip="$1"
  echo ""
  info "Windows detected. Run this in an Administrator PowerShell:"
  echo ""
  echo "    irm {{BASE_URL}}/_/setup.ps1 | iex"
  echo ""
  echo "  To uninstall later:"
  echo ""
  echo "    irm {{BASE_URL}}/_/setup.ps1 -OutFile ln-setup.ps1"
  echo "    .\\ln-setup.ps1 -Remove"
  echo ""
  echo "  ── Manual alternative ──"
  echo ""
  echo "    File: C:\\Windows\\System32\\drivers\\etc\\hosts"
  echo "    Line: $ip    $HOSTNAME    $MARKER"
  echo ""
  echo "  1. Open Notepad as Administrator"
  echo "  2. File → Open → C:\\Windows\\System32\\drivers\\etc\\hosts"
  echo "  3. Add the line above at the end"
  echo "  4. Save and close"
  echo "  5. Run: ipconfig /flushdns"
  echo ""
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
  echo ""
  echo "  ╭─────────────────────────────────────╮"
  echo "  │   {{SITE_HOST}} — local DNS setup    │"
  echo "  ╰─────────────────────────────────────╯"
  echo ""

  local os
  os=$(detect_os)

  # Handle --remove
  if [ "${1:-}" = "--remove" ] || [ "${1:-}" = "remove" ] || [ "${1:-}" = "uninstall" ]; then
    check_root
    remove_hosts_entry "$os"
    return 0
  fi

  # Resolve IP
  info "Resolving $TARGET_HOST..."
  local ip
  ip=$(resolve_ip)
  ok "Resolved to $ip"

  # Platform-specific install
  case "$os" in
    linux|macos)
      check_root
      install_hosts_entry "$ip" "$os"
      ;;
    windows)
      windows_instructions "$ip"
      ;;
    *)
      err "Unsupported OS: $(uname -s)"
      err "Manually add this to your hosts file:"
      echo "    $ip    $HOSTNAME    $MARKER"
      exit 1
      ;;
  esac
}

main "$@"
