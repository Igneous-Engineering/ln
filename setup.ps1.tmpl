<#
.SYNOPSIS
  {{SITE_HOST}} — Configure Windows to resolve 'ln' as a hostname.

.DESCRIPTION
  Adds an entry to C:\Windows\System32\drivers\etc\hosts so that 'ln'
  resolves to the {{SITE_HOST}} server. After setup, you can use:

    curl http://ln/yt           # from terminal
    http://ln/yt                # in any browser
    <a href="http://ln/yt">    # in documents

.EXAMPLE
  # Install (run PowerShell as Administrator):
  irm {{BASE_URL}}/_/setup.ps1 | iex

  # Or download and run:
  .\setup.ps1

  # To uninstall:
  .\setup.ps1 -Remove

.NOTES
  Requires Administrator privileges.
#>

param(
  [switch]$Remove
)

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

$Hostname   = "ln"
$TargetHost = "{{SITE_HOST}}"
$Marker     = "# {{SITE_HOST}} shortlink service"
$HostsFile  = "$env:SystemRoot\System32\drivers\etc\hosts"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

function Write-Info  { param($msg) Write-Host "→ $msg" -ForegroundColor Cyan }
function Write-Ok    { param($msg) Write-Host "✔ $msg" -ForegroundColor Green }
function Write-Warn  { param($msg) Write-Host "! $msg" -ForegroundColor Yellow }
function Write-Err   { param($msg) Write-Host "✘ $msg" -ForegroundColor Red }

function Assert-Admin {
  $identity  = [Security.Principal.WindowsIdentity]::GetCurrent()
  $principal = [Security.Principal.WindowsPrincipal]$identity
  if (-not $principal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    Write-Err "This script must be run as Administrator."
    Write-Host ""
    Write-Host "  Right-click PowerShell → 'Run as administrator', then try again." -ForegroundColor DarkGray
    exit 1
  }
}

function Resolve-TargetIP {
  Write-Info "Resolving $TargetHost..."
  try {
    $addresses = [System.Net.Dns]::GetHostAddresses($TargetHost)
    $ipv4 = $addresses | Where-Object { $_.AddressFamily -eq "InterNetwork" } | Select-Object -First 1
    if (-not $ipv4) {
      $ipv4 = $addresses | Select-Object -First 1
    }
    $ip = $ipv4.IPAddressToString
    Write-Ok "Resolved to $ip"
    return $ip
  }
  catch {
    Write-Err "Could not resolve $TargetHost. Check your DNS / internet connection."
    exit 1
  }
}

function Flush-Dns {
  Write-Info "Flushing DNS cache..."
  ipconfig /flushdns | Out-Null
}

# ---------------------------------------------------------------------------
# Install
# ---------------------------------------------------------------------------

function Install-HostsEntry {
  param($IP)

  Assert-Admin

  $content = Get-Content -Path $HostsFile -Raw -ErrorAction SilentlyContinue
  if ($content -and $content.Contains($Marker)) {
    Write-Warn "Entry already exists in hosts file. Updating..."
    Remove-HostsEntry -Quiet
  }

  Write-Info "Adding '$Hostname' → $IP to $HostsFile"
  $entry = "$IP    $Hostname    $Marker"
  Add-Content -Path $HostsFile -Value "`n$entry" -Encoding ASCII

  Flush-Dns

  Write-Ok "Done! You can now use:"
  Write-Host ""
  Write-Host "    curl -L http://ln/yt"
  Write-Host "    http://ln/yt               # in any browser"
  Write-Host ""
  Write-Host "  In any hyperlink:  http://ln/yt"
  Write-Host ""
}

# ---------------------------------------------------------------------------
# Remove
# ---------------------------------------------------------------------------

function Remove-HostsEntry {
  param([switch]$Quiet)

  Assert-Admin

  $content = Get-Content -Path $HostsFile -Raw -ErrorAction SilentlyContinue
  if (-not $content -or -not $content.Contains($Marker)) {
    if (-not $Quiet) { Write-Warn "No ln entry found in hosts file. Nothing to remove." }
    return
  }

  if (-not $Quiet) { Write-Info "Removing ln entry from $HostsFile" }

  $lines = Get-Content -Path $HostsFile
  $filtered = $lines | Where-Object { $_ -notmatch [regex]::Escape($Marker) }
  $filtered | Set-Content -Path $HostsFile -Encoding ASCII

  Flush-Dns

  if (-not $Quiet) { Write-Ok "Removed. 'ln' will no longer resolve locally." }
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

Write-Host ""
Write-Host "  ╭─────────────────────────────────────╮"
Write-Host "  │   {{SITE_HOST}} — local DNS setup    │"
Write-Host "  ╰─────────────────────────────────────╯"
Write-Host ""

if ($Remove) {
  Remove-HostsEntry
}
else {
  $ip = Resolve-TargetIP
  Install-HostsEntry -IP $ip
}
